# Server-specific values for pi-tools setup.
# Copy to .env.local and fill in real values.

# Default provider name (e.g., lmstudio, ollama)
DEFAULT_PROVIDER=lmstudio

# Default model ID
DEFAULT_MODEL=qwen3.6-27b-mtp

# Provider config in models.json
PROVIDER_NAME=lmstudio
BASE_URL=http://localhost:1234/v1
API_KEY=sk-lm-your-key-here

# MCP servers
MCP_SEARXNG_URL=http://localhost:4005/mcp
